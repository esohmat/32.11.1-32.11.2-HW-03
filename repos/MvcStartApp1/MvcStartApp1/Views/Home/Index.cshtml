
@model List<MvcStartApp1.Models.Db.Request>

@{
    ViewData["Title"] = "Request Logs";
}

<div class="container mt-4">
    <h2>📋 История запросов</h2>

    @if (Model?.Count > 0)
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Дата и время</th>
                    <th>Запрос</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td>@log.Id.ToString().Substring(0, 8)...</td>
                        <td>@log.Date.ToString("dd.MM.yyyy HH:mm:ss")</td>
                        <td><code>@log.Url</code></td>
                    </tr>
                }
            </tbody>
        </table>

        <p class="text-muted">Всего записей: @Model.Count</p>
    }
    else
    {
        <div class="alert alert-info">
            📭 Логи пока отсутствуют. Совершите несколько запросов к приложению.
        </div>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">← На главную</a>
</div>